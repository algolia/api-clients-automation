      /// <summary>
      /// Sets (or replaces) the ingestion transporter used by *WithTransformation helpers.
      /// The ingestion transporter is created using the region from <paramref name="transformationOptions"/>
      /// and Ingestion API defaults; pass an <see cref="ClientOptions"/> inside
      /// <paramref name="transformationOptions"/> to override specific defaults.
      /// See https://www.algolia.com/doc/libraries/sdk/methods/ingestion
      /// </summary>
      public void SetTransformationOptions(TransformationOptions transformationOptions)
      {
        if (transformationOptions == null)
          throw new ArgumentNullException(nameof(transformationOptions));

        var ingestionConfig = new IngestionConfig(
          _transport._algoliaConfig.AppId,
          _transport._algoliaConfig.ApiKey,
          transformationOptions.Region
        );

        if (transformationOptions.ClientOptions != null)
        {
          var opts = transformationOptions.ClientOptions;
          if (opts.CustomHosts != null) ingestionConfig.CustomHosts = opts.CustomHosts;
          if (opts.ConnectTimeout.HasValue) ingestionConfig.ConnectTimeout = opts.ConnectTimeout;
          if (opts.ReadTimeout.HasValue) ingestionConfig.ReadTimeout = opts.ReadTimeout;
          if (opts.WriteTimeout.HasValue) ingestionConfig.WriteTimeout = opts.WriteTimeout;
          if (opts.Compression.HasValue) ingestionConfig.Compression = opts.Compression.Value;
          if (opts.DefaultHeaders != null) ingestionConfig.DefaultHeaders = opts.DefaultHeaders;
        }

        _ingestionTransporter = new IngestionClient(ingestionConfig, _loggerFactory);
      }

